# Database (RDS PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"
# Production: postgresql://taskflow_admin:<password>@<rds-endpoint>:5432/taskflow?schema=public

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Redis (ElastiCache)
REDIS_URL="redis://localhost:6379"
# Production: redis://<elasticache-endpoint>:6379

# AWS S3
AWS_REGION="us-east-1"
AWS_S3_BUCKET="taskflow-app-baxdev"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Email (SMTP) - bypassed in development, logs to console instead
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="noreply@taskflow.app"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
