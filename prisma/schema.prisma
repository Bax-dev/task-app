generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
  GUEST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  REJECTED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMMENTED
  INVITATION_RECEIVED
  INVITATION_ACCEPTED
  PROJECT_CREATED
  SPACE_CREATED
  MEMBER_JOINED
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum LinkType {
  BLOCKS
  BLOCKED_BY
  DUPLICATES
  DUPLICATED_BY
  CLONES
  CLONED_BY
  RELATES_TO
}

enum FieldType {
  DROPDOWN
  LABEL
  CHECKBOX
  DATE
  TEXT
  NUMBER
}

enum AutomationTrigger {
  TASK_CREATED
  TASK_UPDATED
  TASK_STATUS_CHANGED
  TASK_ASSIGNED
  TASK_COMMENT_ADDED
  SPRINT_STARTED
  SPRINT_COMPLETED
}

enum AutomationAction {
  ASSIGN_USER
  CHANGE_STATUS
  ADD_LABEL
  ADD_COMMENT
  SEND_NOTIFICATION
  MOVE_TO_SPRINT
}

enum IntegrationType {
  GITHUB
  GITLAB
  BITBUCKET
  SLACK
  CONFLUENCE
  FIGMA
  ZENDESK
  SALESFORCE
}

// ─── Models ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String?
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          Membership[]
  createdTasks         Task[]           @relation("TaskCreatedBy")
  taskAssignments      TaskAssignment[]
  createdProjects      Project[]        @relation("ProjectCreatedBy")
  createdOrganizations Organization[]   @relation("OrgCreatedBy")
  createdSpaces        Space[]          @relation("SpaceCreatedBy")
  notifications        Notification[]
  notes                Note[]           @relation("NoteCreatedBy")
  activityLogs         ActivityLog[]    @relation("ActivityLogCreatedBy")
  comments             Comment[]        @relation("CommentCreatedBy")
  createdBoards        Board[]          @relation("BoardCreatedBy")
  createdSprints       Sprint[]         @relation("SprintCreatedBy")
  createdAutomations   Automation[]     @relation("AutomationCreatedBy")
  createdIntegrations  Integration[]    @relation("IntegrationCreatedBy")
  savedFilters         SavedFilter[]    @relation("SavedFilterCreatedBy")
  dashboards           Dashboard[]      @relation("DashboardCreatedBy")
  createdSubtasks      Subtask[]        @relation("SubtaskCreatedBy")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  taskCounter Int      @default(0)
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User          @relation("OrgCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  memberships  Membership[]
  spaces       Space[]
  invitations  Invitation[]
  notes        Note[]
  activityLogs ActivityLog[]
  labels       Label[]
  issueTypes   IssueType[]
  customFields CustomField[]
  workflows    Workflow[]
  automations  Automation[]
  integrations Integration[]
  savedFilters SavedFilter[]
  dashboards   Dashboard[]
  sprints      Sprint[]

  @@index([createdById])
  @@index([slug])
}

model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  email          String
  token          String           @unique
  organizationId String           @db.Uuid
  invitedById    String           @db.Uuid
  role           Role             @default(MEMBER)
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

model Space {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  color          String   @default("#7c3aed")
  icon           String   @default("folder")
  organizationId String   @db.Uuid
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SpaceCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  projects     Project[]

  @@index([organizationId])
  @@index([createdById])
}

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  spaceId        String   @db.Uuid
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  tasks        Task[]
  boards       Board[]

  @@index([spaceId])
  @@index([createdById])
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  taskNumber      Int
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  dueDate         DateTime?
  rejectionReason String?
  projectId       String       @db.Uuid
  createdById     String       @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User               @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  assignments      TaskAssignment[]
  activityLogs     ActivityLog[]
  attachments      Attachment[]       @relation("TaskAttachments")
  comments         Comment[]
  sourceLinks      IssueLink[]        @relation("SourceTask")
  targetLinks      IssueLink[]        @relation("TargetTask")
  customFieldValues CustomFieldValue[]
  taskLabels       TaskLabel[]
  sprintTasks      SprintTask[]
  boardColumnId    String?            @db.Uuid
  boardColumn      BoardColumn?       @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  storyPoints      Int?
  issueTypeId      String?            @db.Uuid
  issueType        IssueType?         @relation(fields: [issueTypeId], references: [id], onDelete: SetNull)
  subtasks         Subtask[]

  @@index([projectId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([boardColumnId])
  @@index([issueTypeId])
}

// ─── Subtasks / Checklist ───────────────────────────────

model Subtask {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  completed   Boolean  @default(false)
  position    Int      @default(0)
  taskId      String   @db.Uuid
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy User @relation("SubtaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdById])
}

model TaskAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model Note {
  id             String   @id @default(uuid()) @db.Uuid
  title          String
  content        String   @default("")
  organizationId String   @db.Uuid
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  attachments  Attachment[] @relation("NoteAttachments")

  @@index([organizationId])
  @@index([createdById])
}

model ActivityLog {
  id             String         @id @default(uuid()) @db.Uuid
  description    String
  status         ActivityStatus @default(IN_PROGRESS)
  note           String?
  taskId         String?        @db.Uuid
  organizationId String         @db.Uuid
  createdById    String         @db.Uuid
  loggedAt       DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ActivityLogCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  attachments  Attachment[] @relation("ActivityLogAttachments")

  @@index([organizationId])
  @@index([createdById])
  @@index([taskId])
  @@index([loggedAt])
}

model Attachment {
  id            String   @id @default(uuid()) @db.Uuid
  fileName      String
  fileKey       String
  fileUrl       String
  fileSize      Int
  mimeType      String
  taskId        String?  @db.Uuid
  activityLogId String?  @db.Uuid
  noteId        String?  @db.Uuid
  uploadedById  String   @db.Uuid
  createdAt     DateTime @default(now())

  task        Task?        @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
  activityLog ActivityLog? @relation("ActivityLogAttachments", fields: [activityLogId], references: [id], onDelete: Cascade)
  note        Note?        @relation("NoteAttachments", fields: [noteId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([activityLogId])
  @@index([noteId])
  @@index([uploadedById])
}

// ─── Boards ─────────────────────────────────────────────

model Board {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  projectId   String   @db.Uuid
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User          @relation("BoardCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  columns   BoardColumn[]

  @@index([projectId])
  @@index([createdById])
}

model BoardColumn {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  position Int
  wipLimit Int?
  boardId  String @db.Uuid

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

// ─── Labels ─────────────────────────────────────────────

model Label {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  color          String   @default("#6366f1")
  organizationId String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taskLabels   TaskLabel[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model TaskLabel {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  labelId   String   @db.Uuid
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([taskId])
  @@index([labelId])
}

// ─── Comments ───────────────────────────────────────────

model Comment {
  id          String   @id @default(uuid()) @db.Uuid
  content     String
  taskId      String   @db.Uuid
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy User @relation("CommentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdById])
}

// ─── Issue Types ────────────────────────────────────────

model IssueType {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  icon           String   @default("circle")
  color          String   @default("#6366f1")
  description    String?
  organizationId String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customFields CustomField[]
  workflows    Workflow[]
  tasks        Task[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ─── Custom Fields ──────────────────────────────────────

model CustomField {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  fieldType      FieldType
  options        Json?
  required       Boolean   @default(false)
  issueTypeId    String?   @db.Uuid
  organizationId String    @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  issueType    IssueType?        @relation(fields: [issueTypeId], references: [id], onDelete: SetNull)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values       CustomFieldValue[]

  @@index([organizationId])
  @@index([issueTypeId])
}

model CustomFieldValue {
  id            String   @id @default(uuid()) @db.Uuid
  value         String
  customFieldId String   @db.Uuid
  taskId        String   @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, taskId])
  @@index([taskId])
  @@index([customFieldId])
}

// ─── Issue Links ────────────────────────────────────────

model IssueLink {
  id           String   @id @default(uuid()) @db.Uuid
  sourceTaskId String   @db.Uuid
  targetTaskId String   @db.Uuid
  linkType     LinkType
  createdAt    DateTime @default(now())

  sourceTask Task @relation("SourceTask", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TargetTask", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, linkType])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

// ─── Sprints ────────────────────────────────────────────

model Sprint {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  goal           String?
  startDate      DateTime?
  endDate        DateTime?
  status         SprintStatus @default(PLANNING)
  organizationId String       @db.Uuid
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SprintCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  sprintTasks  SprintTask[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
}

model SprintTask {
  id          String   @id @default(uuid()) @db.Uuid
  sprintId    String   @db.Uuid
  taskId      String   @db.Uuid
  storyPoints Int?
  createdAt   DateTime @default(now())

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([sprintId, taskId])
  @@index([sprintId])
  @@index([taskId])
}

// ─── Workflows ──────────────────────────────────────────

model Workflow {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  issueTypeId    String?  @db.Uuid
  organizationId String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  issueType    IssueType?           @relation(fields: [issueTypeId], references: [id], onDelete: SetNull)
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        WorkflowStep[]
  transitions  WorkflowTransition[]

  @@index([organizationId])
  @@index([issueTypeId])
}

model WorkflowStep {
  id         String @id @default(uuid()) @db.Uuid
  name       String
  position   Int
  workflowId String @db.Uuid

  workflow        Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromStep")
  toTransitions   WorkflowTransition[] @relation("ToStep")

  @@index([workflowId])
}

model WorkflowTransition {
  id         String @id @default(uuid()) @db.Uuid
  name       String
  fromStepId String @db.Uuid
  toStepId   String @db.Uuid
  conditions Json?
  workflowId String @db.Uuid

  fromStep WorkflowStep @relation("FromStep", fields: [fromStepId], references: [id], onDelete: Cascade)
  toStep   WorkflowStep @relation("ToStep", fields: [toStepId], references: [id], onDelete: Cascade)
  workflow Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([fromStepId])
  @@index([toStepId])
}

// ─── Automations ────────────────────────────────────────

model Automation {
  id             String            @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  trigger        AutomationTrigger
  conditions     Json?
  action         AutomationAction
  actionConfig   Json?
  enabled        Boolean           @default(true)
  organizationId String            @db.Uuid
  createdById    String            @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("AutomationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdById])
  @@index([trigger])
}

// ─── Integrations ───────────────────────────────────────

model Integration {
  id             String          @id @default(uuid()) @db.Uuid
  type           IntegrationType
  name           String
  config         Json?
  enabled        Boolean         @default(true)
  organizationId String          @db.Uuid
  createdById    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("IntegrationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
}

// ─── Saved Filters ──────────────────────────────────────

model SavedFilter {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  query          Json
  shared         Boolean  @default(false)
  organizationId String   @db.Uuid
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SavedFilterCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdById])
}

// ─── Dashboards ─────────────────────────────────────────

model Dashboard {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  layout         Json?
  organizationId String   @db.Uuid
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("DashboardCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdById])
}
